{
  "name": "snap-sport-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra"
  ],
  "scripts": {
    "dev": "concurrently -n \"frontend,admin,api\" -c \"blue,magenta,green\" --kill-others-on-fail \"npm run dev --prefix apps/frontend\" \"npm run dev --prefix apps/admin\" \"npm run dev --prefix apps/api\"",
    "dev:frontend": "npm run dev --prefix apps/frontend",
    "dev:admin": "npm run dev --prefix apps/admin",
    "dev:api": "npm run dev --prefix apps/api",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules",
    "kill-ports": "npx kill-port 3000 3001 4000"
  },
  "devDependencies": {
    "concurrently": "^9",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2"
}
